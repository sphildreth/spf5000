    "@vitejs/plugin-react": "^5.0.1",
    "@playwright/test": "^1.50.1",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^3.1.4"
