[Desktop Entry]
Type=Application
Name=SPF5000 Kiosk
Comment=Launch the SPF5000 display in Chromium kiosk mode
Exec=/bin/sh -lc "sleep __KIOSK_DELAY_SECONDS__; if [ -x /usr/bin/unclutter ]; then /usr/bin/unclutter -idle 0.5 -root -visible >/dev/null 2>&1 & fi; exec __CHROMIUM_BINARY__ --kiosk --noerrdialogs --disable-infobars --disable-session-crashed-bubble --no-first-run --no-default-browser-check --password-store=basic --incognito __DISPLAY_URL__"
Terminal=false
StartupNotify=false
X-GNOME-Autostart-enabled=true
