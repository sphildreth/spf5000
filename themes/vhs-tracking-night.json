{
  "id": "vhs-tracking-night",
  "name": "VHS Tracking Night",
  "description": "Moody VHS-era purples, scanline-adjacent contrast, and analog-night vibes.",
  "version": "1.0.0",
  "mode": "dark",
  "tokens": {
    "colors": {
      "background_primary": "#040408",
      "background_secondary": "#0A0A12",
      "surface_default": "#171422",
      "surface_elevated": "#221B31",
      "surface_overlay": "rgba(10,9,17,0.84)",
      "text_primary": "#F1EBFF",
      "text_secondary": "#CABDE2",
      "text_muted": "#8F82A8",
      "border_default": "#594A70",
      "accent_primary": "#9B62FF",
      "accent_secondary": "#FF5AA5",
      "status_success": "#74DDA6",
      "status_warning": "#EBCB6C",
      "status_error": "#FF6775",
      "shadow_color": "rgba(0,0,0,0.54)",
      "glow_color": "rgba(155,98,255,0.18)",
      "overlay_backdrop": "rgba(0,0,0,0.50)"
    },
    "typography": {
      "font_family_base": "Inter, ui-sans-serif, system-ui, sans-serif",
      "font_family_display": "Orbitron, Inter, ui-sans-serif, system-ui, sans-serif",
      "font_weight_normal": 400,
      "font_weight_medium": 500,
      "font_weight_bold": 700,
      "font_size_body": "16px",
      "font_size_small": "13px",
      "font_size_widget_label": "13px",
      "font_size_widget_temp": "42px",
      "font_size_heading": "24px",
      "font_size_alert_headline": "52px",
      "font_size_alert_subheading": "24px"
    },
    "spacing": {
      "space_xs": "4px",
      "space_sm": "8px",
      "space_md": "12px",
      "space_lg": "16px",
      "space_xl": "24px",
      "space_2xl": "32px"
    },
    "motion": {
      "duration_fast": "120ms",
      "duration_normal": "220ms",
      "duration_slow": "420ms",
      "easing_standard": "cubic-bezier(0.2, 0, 0, 1)",
      "easing_emphasized": "cubic-bezier(0.2, 0.8, 0.2, 1)"
    },
    "shape": {
      "radius_card": "8px",
      "radius_button": "8px",
      "radius_badge": "999px",
      "radius_overlay": "12px",
      "border_width_standard": "1px",
      "border_width_emphasis": "2px",
      "shadow_card": "0 8px 24px rgba(0,0,0,0.35)",
      "shadow_overlay": "0 14px 36px rgba(0,0,0,0.45)",
      "glow_accent": "rgba(155,98,255,0.18)",
      "glow_logo": "rgba(155,98,255,0.18)",
      "blur_overlay": "10px",
      "opacity_widget_background": 0.82,
      "opacity_overlay_background": 0.42
    }
  },
  "components": {
    "button_primary": {
      "background": "var(--color-accent-primary)",
      "color": "var(--color-text-on-accent)",
      "border": "none",
      "border_radius": "var(--shape-radius-md)",
      "background_token": "accent_primary",
      "text_token": "text_primary"
    },
    "card": {
      "background": "var(--color-surface-default)",
      "border": "1px solid var(--color-border-default)",
      "border_radius": "var(--shape-radius-lg)",
      "background_token": "surface_default",
      "border_token": "border_default"
    },
    "input": {
      "background": "var(--color-background-secondary)",
      "border": "1px solid var(--color-border-default)",
      "color": "var(--color-text-primary)",
      "border_radius": "var(--shape-radius-md)"
    }
  },
  "contexts": {
    "home_city_accent": {
      "style": "accent_glow",
      "highlight_color": "var(--color-accent-primary)",
      "badge_background": "var(--color-accent-primary-muted)",
      "badge_text": "var(--color-accent-primary)"
    }
  }
}