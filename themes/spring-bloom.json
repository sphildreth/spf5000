{
  "id": "spring-bloom",
  "name": "Spring Bloom",
  "description": "Fresh floral greens, petal pinks, and bright spring morning contrast.",
  "version": "1.0.0",
  "mode": "dark",
  "tokens": {
    "colors": {
      "background_primary": "#0D1410",
      "background_secondary": "#151F18",
      "surface_default": "#223226",
      "surface_elevated": "#2E4031",
      "surface_overlay": "rgba(18,28,21,0.78)",
      "text_primary": "#F8FFF7",
      "text_secondary": "#D7E9D6",
      "text_muted": "#A6C2A6",
      "border_default": "#628162",
      "accent_primary": "#8FD36B",
      "accent_secondary": "#FF8FC2",
      "status_success": "#6BEE9A",
      "status_warning": "#FFE078",
      "status_error": "#FF7E86",
      "shadow_color": "rgba(0,0,0,0.42)",
      "glow_color": "rgba(143,211,107,0.20)",
      "overlay_backdrop": "rgba(0,0,0,0.32)"
    },
    "typography": {
      "font_family_base": "Inter, ui-sans-serif, system-ui, sans-serif",
      "font_family_display": "Orbitron, Inter, ui-sans-serif, system-ui, sans-serif",
      "font_weight_normal": 400,
      "font_weight_medium": 500,
      "font_weight_bold": 700,
      "font_size_body": "16px",
      "font_size_small": "13px",
      "font_size_widget_label": "13px",
      "font_size_widget_temp": "42px",
      "font_size_heading": "24px",
      "font_size_alert_headline": "52px",
      "font_size_alert_subheading": "24px"
    },
    "spacing": {
      "space_xs": "4px",
      "space_sm": "8px",
      "space_md": "12px",
      "space_lg": "16px",
      "space_xl": "24px",
      "space_2xl": "32px"
    },
    "motion": {
      "duration_fast": "120ms",
      "duration_normal": "220ms",
      "duration_slow": "420ms",
      "easing_standard": "cubic-bezier(0.2, 0, 0, 1)",
      "easing_emphasized": "cubic-bezier(0.2, 0.8, 0.2, 1)"
    },
    "shape": {
      "radius_card": "16px",
      "radius_button": "10px",
      "radius_badge": "999px",
      "radius_overlay": "18px",
      "border_width_standard": "1px",
      "border_width_emphasis": "2px",
      "shadow_card": "0 10px 30px rgba(0,0,0,0.35)",
      "shadow_overlay": "0 16px 40px rgba(0,0,0,0.45)",
      "glow_accent": "rgba(143,211,107,0.20)",
      "glow_logo": "rgba(143,211,107,0.20)",
      "blur_overlay": "12px",
      "opacity_widget_background": 0.78,
      "opacity_overlay_background": 0.4
    }
  },
  "components": {
    "button_primary": {
      "background": "var(--color-accent-primary)",
      "color": "var(--color-text-on-accent)",
      "border": "none",
      "border_radius": "var(--shape-radius-md)",
      "background_token": "accent_primary",
      "text_token": "text_primary"
    },
    "card": {
      "background": "var(--color-surface-default)",
      "border": "1px solid var(--color-border-default)",
      "border_radius": "var(--shape-radius-lg)",
      "background_token": "surface_default",
      "border_token": "border_default"
    },
    "input": {
      "background": "var(--color-background-secondary)",
      "border": "1px solid var(--color-border-default)",
      "color": "var(--color-text-primary)",
      "border_radius": "var(--shape-radius-md)"
    }
  },
  "contexts": {
    "home_city_accent": {
      "style": "house_icon",
      "highlight_color": "var(--color-accent-primary)",
      "badge_background": "var(--color-accent-primary-muted)",
      "badge_text": "var(--color-accent-primary)"
    }
  }
}