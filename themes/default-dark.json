{
  "id": "default-dark",
  "name": "Default Dark",
  "description": "The default dark theme for SPF5000. Clean, neutral, and unobtrusive.",
  "version": "1.0.0",
  "tokens": {
    "colors": {
      "background_primary": "#0f0f0f",
      "background_secondary": "#1a1a1a",
      "background_elevated": "#242424",
      "background_overlay": "rgba(0, 0, 0, 0.72)",
      "surface_default": "#1e1e1e",
      "surface_hover": "#2a2a2a",
      "surface_active": "#333333",
      "border_default": "#2e2e2e",
      "border_subtle": "#1f1f1f",
      "border_strong": "#444444",
      "text_primary": "#f0f0f0",
      "text_secondary": "#a0a0a0",
      "text_disabled": "#555555",
      "text_on_accent": "#ffffff",
      "accent_primary": "#4a9eff",
      "accent_primary_hover": "#6ab2ff",
      "accent_primary_muted": "rgba(74, 158, 255, 0.18)",
      "accent_danger": "#ff5555",
      "accent_danger_hover": "#ff7777",
      "accent_warning": "#f5a623",
      "accent_success": "#4caf7d",
      "display_background": "#000000",
      "display_overlay_text": "#ffffff",
      "display_overlay_shadow": "rgba(0, 0, 0, 0.85)"
    },
    "typography": {
      "font_family_base": "'Inter', 'Segoe UI', system-ui, sans-serif",
      "font_family_display": "'Inter', 'Segoe UI', system-ui, sans-serif",
      "font_family_mono": "'JetBrains Mono', 'Fira Code', monospace",
      "font_size_xs": "0.75rem",
      "font_size_sm": "0.875rem",
      "font_size_md": "1rem",
      "font_size_lg": "1.125rem",
      "font_size_xl": "1.375rem",
      "font_size_2xl": "1.75rem",
      "font_weight_normal": "400",
      "font_weight_medium": "500",
      "font_weight_semibold": "600",
      "font_weight_bold": "700",
      "line_height_tight": "1.25",
      "line_height_normal": "1.5",
      "line_height_relaxed": "1.75"
    },
    "spacing": {
      "xs": "0.25rem",
      "sm": "0.5rem",
      "md": "1rem",
      "lg": "1.5rem",
      "xl": "2rem",
      "2xl": "3rem"
    },
    "motion": {
      "duration_fast": "120ms",
      "duration_normal": "220ms",
      "duration_slow": "380ms",
      "easing_default": "ease-in-out",
      "easing_spring": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    },
    "shape": {
      "radius_sm": "4px",
      "radius_md": "8px",
      "radius_lg": "12px",
      "radius_xl": "16px",
      "radius_full": "9999px"
    }
  },
  "components": {
    "button_primary": {
      "background": "var(--color-accent-primary)",
      "color": "var(--color-text-on-accent)",
      "border": "none",
      "border_radius": "var(--shape-radius-md)"
    },
    "card": {
      "background": "var(--color-surface-default)",
      "border": "1px solid var(--color-border-default)",
      "border_radius": "var(--shape-radius-lg)"
    },
    "input": {
      "background": "var(--color-background-secondary)",
      "border": "1px solid var(--color-border-default)",
      "color": "var(--color-text-primary)",
      "border_radius": "var(--shape-radius-md)"
    }
  },
  "contexts": {
    "home_city_accent": {
      "style": "default",
      "highlight_color": "var(--color-accent-primary)",
      "badge_background": "var(--color-accent-primary-muted)",
      "badge_text": "var(--color-accent-primary)"
    }
  }
}
